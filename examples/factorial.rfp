[
  [$x x]                       $force

  ; Y-Combinator
  [$f
    [$x [^x x] f]
    [$x [^x x] f]
    force
  ] $Y

  ; rec: syntax sugar for applying the Y-Combinator
  [$g [^g Y]] $rec

  ; factorial
  [$self $n $acc
    n 0 eq if
    [acc]
    [^acc ^n * ^n 1 - self]
  ] rec $factorial

  1 18 factorial print
]
