[
  [$x x]                                  $force
  [$fn $arg [^arg fn]]                    $partial
  [$f [$x [^x x] f] [$x [^x x] f] force]  $Y
  [^Y partial]                            $rec

  [$self $n
    n print
    n 1 eq if
    ['done print]
    [
      n 1 & 0 eq if
      [n 2 / self]
      [3 n * 1 + self]
    ]
  ] rec $collatz

  'collatz print
  100 collatz
]
