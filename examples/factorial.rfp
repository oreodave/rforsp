[
  [$x x]                       $force
  [force cswap $_ force]       $if
  [$f $t $c $fn ^f ^t ^c fn]   $endif

  ; Y-Combinator
  [$f
    [$x [^x x] f]
    [$x [^x x] f]
    force
  ] $Y

  ; rec: syntax sugar for applying the Y-Combinator
  [$g [^g Y]] $rec

  ; factorial
  [$self $n
    n 0 eq if
        [1]
        [^n 1 - self ^n *]
  ] rec $factorial

  18 factorial print
]
