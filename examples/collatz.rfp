;;; collatz.rfp: Computing the collatz chain in rForsp.
;; This is an extremely simple program, similar to `factorial.rfp` (which see).

[
  [$self $n
    n print
    n 1 eq if
    ['done print]
    [
      n 1 & 0 eq if
      [n 2 /]
      [3 n * 1 +]
      self
    ]
  ] rec $collatz

  'collatz print
  1 34 <<
  1 -
  collatz
]
